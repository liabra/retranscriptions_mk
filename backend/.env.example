# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/retranscriptions_db

# JWT Auth
SECRET_KEY=changez-moi-en-production-clé-aléatoire-512-bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Chiffrement IBAN (AES-256) — générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changez-moi-en-production

# App
APP_NAME=Gestion Retranscriptions
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Emails (V2)
# SENDGRID_API_KEY=
# EMAIL_FROM=

# Fichiers
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500
