# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/retranscriptions_db

# JWT Auth
SECRET_KEY=changez-moi-en-production-clé-aléatoire-512-bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Chiffrement IBAN (AES-256) — générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changez-moi-en-production

# App
APP_NAME=Gestion Retranscriptions
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Emails SMTP — tous optionnels (emails loggés si absent, jamais d'erreur)
# Compatible Gmail, Outlook, OVH, Mailgun, Brevo, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@email.com
# SMTP_PASSWORD=mot-de-passe-ou-app-password
# EMAIL_FROM=A2C Retranscriptions <contact@a2c.fr>
# ADMIN_EMAIL=admin@a2c.fr   # Reçoit la notif quand un correcteur livre

# Fichiers
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500
